class Trip {
    {static}-int lastId
    -int id
    +LocalDateTime date
    +Hashset<Condition> conditions
    +double startKm
    +double endKm
    +string startCity
    +string endCity
    +string extraInfo

    +Trip()
    +Trip()
}

class TripManager {
    +ObservableList<Trip> trips

    +TripManager()
    +getSumOfKilometers()
    +addTrip()
    +updateTrip()
    +deleteTrip()
    +saveToDatabase()
    -loadDatabase()
}

class Database {
}

enum Condition {
